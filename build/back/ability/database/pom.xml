<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <artifactId>back</artifactId>
        <groupId>cn.fyy.build</groupId>
        <version>1.0</version>
        <relativePath>../../pom.xml</relativePath>
    </parent>

    <artifactId>database</artifactId>
    <version>0.0.1</version>
    <name>database</name>
    <description>数据库ORM模块</description>

    <properties>
        <!-- 实体 -->
        <java-bean.version>0.0.1</java-bean.version>
    </properties>

    <dependencies>
        <!-- JPA -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-jpa</artifactId>
        </dependency>

        <!-- mysql -->
        <dependency>
            <groupId>com.mysql</groupId>
            <artifactId>mysql-connector-j</artifactId>
        </dependency>

        <!-- 连接池 -->
        <dependency>
            <groupId>com.alibaba</groupId>
            <artifactId>druid-spring-boot-starter</artifactId>
        </dependency>

        <!-- 连接池Web监控页面需要 -->
        <dependency>
            <groupId>jakarta.servlet</groupId>
            <artifactId>jakarta.servlet-api</artifactId>
            <scope>provided</scope>
        </dependency>

        <!--
            seata 分布式事务
            注意点：
                1、会报错因为没有引用protostuff、fury但这两个是用来做json格式化有Jackson即可，可以忽略警告；
                2、数据库读写分离连接要分开即使是127.0.0.1、localhost也需要分开，如果同链接同地址，读写分离会导致写链接因为主链接先注入，读链接后注入，从而覆盖防火墙策略，导致不能增删改
        -->
        <dependency>
            <groupId>com.alibaba.cloud</groupId>
            <artifactId>spring-cloud-starter-alibaba-seata</artifactId>
        </dependency>

        <!-- 实体 -->
        <dependency>
            <groupId>cn.fyy.build</groupId>
            <artifactId>common-bean</artifactId>
            <version>${java-bean.version}</version>
        </dependency>
    </dependencies>
</project>